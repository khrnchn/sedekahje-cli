{
  "name": "sedekahje-cli",
  "version": "0.1.0",
  "description": "CLI & TUI for sedekah.je — browse Malaysian donation QR codes from the terminal",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "bin": {
    "sedekahje": "src/index.tsx"
  },
  "scripts": {
    "dev": "bun run src/index.tsx",
    "build": "bun build src/index.tsx --compile --outfile sedekahje",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.1.87",
    "@opentui/react": "^0.1.87",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fuse.js": "^7.1.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.4",
    "react-reconciler": "^0.33.0"
  }
}
